# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001/api

# CORS (Express on Render uses NODE_ENV=production — localhost is still allowed unless you set CORS_ALLOW_LOCALHOST=false)
# Comma-separated list of extra allowed browser origins (staging, mobile web, etc.)
CORS_ORIGINS=
# Set to "false" on production API if you do not want any http://localhost:* / 127.0.0.1:* origin
CORS_ALLOW_LOCALHOST=true

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=your-mongodb-uri

# Razorpay Payment Gateway (use TEST keys from dashboard → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (local: Gmail SMTP; Render: use RESEND_API_KEY)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password-no-spaces
EMAIL_FROM=CricBox <your@gmail.com>
RESEND_API_KEY=
RESEND_FROM=CricBox <onboarding@resend.dev>
