# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001/api

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=your-mongodb-uri

# Cashfree Payment Gateway (PG 2.0)
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key
# sandbox | production (must match your API keys)
CASHFREE_ENVIRONMENT=production
# Set true only to skip real Cashfree (local testing without keys)
# CASHFREE_USE_MOCK=true

# Email (local: Gmail SMTP; Render: use RESEND_API_KEY)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password-no-spaces
EMAIL_FROM=BoxCric <your@gmail.com>
RESEND_API_KEY=
RESEND_FROM=BoxCric <onboarding@resend.dev>
