# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001/api

# JWT
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=your-mongodb-uri

# Razorpay Payment Gateway (use TEST keys from dashboard → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email (local: Gmail SMTP; Render: use RESEND_API_KEY)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password-no-spaces
EMAIL_FROM=CricBox <your@gmail.com>
RESEND_API_KEY=
RESEND_FROM=CricBox <onboarding@resend.dev>
